{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "repository.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["repository_version", "created_at", "validation_scope", "intake", "pending_window"],
  "properties": {
    "repository_version": {"type": "integer", "const": 3},
    "created_at": {"type": "string"},
    "validation_scope": {"type": "string"},
    "intake": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["adapter", "conversation", "last_marker_id"],
          "properties": {
            "adapter": {"type": "string", "enum": ["scripted_chat", "macos_computer_use_v1"]},
            "conversation": {"type": "string", "const": "file-transfer-assistant"},
            "last_marker_id": {"type": "string"}
          }
        }
      ]
    },
    "pending_window": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["adapter", "conversation", "previous_marker_id", "current_marker_id", "messages", "run_id", "task_ids", "publication_selection"],
          "properties": {
            "adapter": {"type": "string", "enum": ["scripted_chat", "macos_computer_use_v1"]},
            "conversation": {"type": "string", "const": "file-transfer-assistant"},
            "previous_marker_id": {"type": "string"},
            "current_marker_id": {"type": "string"},
            "messages": {"type": "array", "items": {"type": "object"}},
            "run_id": {"type": "string"},
            "task_ids": {"type": "array", "items": {"type": "string"}},
            "publication_selection": {"type": "string", "enum": ["none", "auto"]}
          }
        }
      ]
    }
  }
}
