{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "run.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "operation",
    "started_at",
    "completed_at",
    "status",
    "input_window",
    "created_task_ids",
    "attempted_task_ids",
    "recovered_by_run"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 2},
    "run_id": {"type": "string"},
    "operation": {"type": "string", "enum": ["run", "retry"]},
    "started_at": {"type": "string"},
    "completed_at": {"type": ["string", "null"]},
    "status": {"type": "string", "enum": ["processing", "completed", "interrupted", "failed"]},
    "input_window": {"type": "object", "additionalProperties": true},
    "created_task_ids": {"type": "array", "items": {"type": "string"}},
    "attempted_task_ids": {"type": "array", "items": {"type": "string"}},
    "recovered_by_run": {"type": ["string", "null"]}
  },
  "x-status-invariants": {
    "processing": {"completed_at": "null", "recovered_by_run": "null"},
    "completed": {"completed_at": "string", "recovered_by_run": "null"},
    "interrupted": {"completed_at": "string", "recovered_by_run": "any"},
    "failed": {"completed_at": "string", "recovered_by_run": "null"}
  }
}
