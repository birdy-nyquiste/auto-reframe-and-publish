{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rewrite-attempt-failure.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "attempt_version",
    "task_id",
    "run_id",
    "phase",
    "error_category",
    "error_code",
    "message",
    "input_sha256",
    "candidate",
    "candidate_manifest"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 2},
    "attempt_version": {"type": "integer", "const": 1},
    "task_id": {"type": "string"},
    "run_id": {"type": "string"},
    "phase": {"type": "string", "enum": ["generation", "validation"]},
    "error_category": {"type": "string"},
    "error_code": {"type": "string"},
    "message": {"type": "string"},
    "input_sha256": {"type": "string"},
    "candidate": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "sha256"],
          "properties": {
            "path": {"type": "string"},
            "sha256": {"type": "string"}
          }
        }
      ]
    },
    "candidate_manifest": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/file_record"}
      ]
    }
  },
  "$defs": {
    "file_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string"}
      }
    }
  }
}
